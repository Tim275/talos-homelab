{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
    ":maintainLockFilesWeekly",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "group:monorepos",
    "group:recommended"
  ],
  "configMigration": true,
  "forkProcessing": "disabled",
  "platformCommit": "enabled",
  "automergeStrategy": "squash",
  "internalChecksAsSuccess": true,
  "separateMinorPatch": true,
  "separateMultipleMajor": false,
  "fetchChangeLogs": "branch",
  "assigneesFromCodeOwners": true,
  "reviewersFromCodeOwners": true,
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths",
    "helmUpdateSubChartArchives"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,
  "dependencyDashboardTitle": "🔄 Renovate Dashboard",
  "dependencyDashboardLabels": [
    "renovate",
    "dependencies"
  ],
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "osvVulnerabilityAlerts": true,
  "schedule": [
    "* * * * *"
  ],
  "timezone": "Europe/Berlin",
  "prConcurrentLimit": 30,
  "prHourlyLimit": 10,
  "branchConcurrentLimit": 35,
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "rebaseLabel": "rebase",
  "stopUpdatingLabel": "stop-updating",
  "semanticCommits": "enabled",
  "labels": [
    "renovate",
    "dependencies"
  ],
  "prHeader": "📦 Dependency update — review labels for risk classification.",
  "prBodyColumns": [
    "Package",
    "Update",
    "Type",
    "New value",
    "Pending",
    "References"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "vulnerability",
      "priority-critical",
      "fast-track"
    ],
    "schedule": [
      "at any time"
    ],
    "automerge": false,
    "minimumReleaseAge": "0 days",
    "prCreation": "immediate"
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 5am on sunday"
    ],
    "automerge": false
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/kubernetes/.+\\.ya?ml$/"
    ]
  },
  "terraform": {
    "managerFilePatterns": [
      "/\\.tf$/",
      "/\\.tofu$/"
    ]
  },
  "kustomize": {
    "managerFilePatterns": [
      "/(^|/)kustomization\\.ya?ml(\\.j2)?$/"
    ]
  },
  "ignorePaths": [
    "**/charts/**",
    "kubernetes/components/**",
    "kubernetes/projects/**",
    "kubernetes/applicationsets/**",
    "kubernetes/clusters/**",
    "kubernetes/platform/developer-platform/backstage/**"
  ],
  "packageRules": [
    {
      "description": "BLOCK: Talos OS image — manual upgrade via talosctl upgrade",
      "matchPackageNames": [
        "/siderolabs/talos/",
        "/siderolabs/installer/",
        "/siderolabs/imager/"
      ],
      "enabled": false
    },
    {
      "description": "BLOCK: Kubelet image — version-coupled to Talos+K8s, must upgrade together via talosctl",
      "matchPackageNames": [
        "/siderolabs/kubelet/"
      ],
      "enabled": false
    },
    {
      "description": "BLOCK: Kubernetes-core — manual via talosctl upgrade-k8s",
      "matchPackageNames": [
        "/^kubernetes$/",
        "/^k8s.io/",
        "/registry.k8s.io/kube-/",
        "/etcd-io/etcd/"
      ],
      "enabled": false
    },
    {
      "description": "BLOCK: Talos-pinned system tooling (cri-tools/cni/containerd come with Talos image)",
      "matchPackageNames": [
        "/cri-tools/",
        "/cni-plugins/",
        "/containerd/"
      ],
      "enabled": false
    },
    {
      "description": "BLOCK: tfvars version-coupling fields (kubernetes_version / talos_machine_config_version)",
      "matchFileNames": [
        "tofu/talos_cluster.auto.tfvars",
        "tofu/talos_image.auto.tfvars"
      ],
      "matchDepNames": [
        "kubernetes_version",
        "talos_machine_config_version"
      ],
      "enabled": false
    },
    {
      "description": "Registry override: Grafana Helm Charts (Loki/Tempo/Mimir/etc)",
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "loki",
        "tempo-distributed",
        "grafana",
        "promtail",
        "grafana-operator",
        "mimir-distributed"
      ],
      "registryUrls": [
        "https://grafana.github.io/helm-charts"
      ]
    },
    {
      "description": "GROUP: Cilium project (cilium + hubble + cilium-cli)",
      "groupName": "cilium",
      "matchPackageNames": [
        "/cilium/cilium/",
        "/cilium/hubble/",
        "/cilium/cilium-cli/"
      ]
    },
    {
      "description": "GROUP: Argo project (argo-cd + argo-rollouts + argo-events + argo-workflows)",
      "groupName": "argo-project",
      "matchPackageNames": [
        "/argoproj/argo-cd/",
        "/argoproj/argo-rollouts/",
        "/argoproj/argo-events/",
        "/argoproj/argo-workflows/",
        "/argo-cd$/",
        "/argo-rollouts$/"
      ]
    },
    {
      "description": "GROUP: Rook+Ceph (same project, must upgrade together)",
      "groupName": "rook-ceph",
      "matchPackageNames": [
        "/rook/",
        "/ceph/"
      ]
    },
    {
      "description": "GROUP: Velero suite (velero + velero-plugin-* — version-coupled)",
      "groupName": "velero-suite",
      "matchPackageNames": [
        "/velero/velero/",
        "/velero/velero-plugin-/",
        "/vmware-tanzu/velero/"
      ]
    },
    {
      "description": "GROUP: CloudNativePG operator + plugin-barman",
      "groupName": "cnpg-suite",
      "matchPackageNames": [
        "/cloudnative-pg/cloudnative-pg/",
        "/cloudnative-pg/plugin-barman-cloud/",
        "/cloudnative-pg/cnpg-i/"
      ]
    },
    {
      "description": "GROUP: Strimzi Kafka operator + CRDs",
      "groupName": "strimzi-kafka",
      "matchPackageNames": [
        "/strimzi/strimzi-kafka-operator/",
        "/strimzi/operator/"
      ]
    },
    {
      "description": "GROUP: Keycloak operator + CR + CLI",
      "groupName": "keycloak",
      "matchPackageNames": [
        "/keycloak/keycloak/",
        "/keycloak/keycloak-operator/",
        "/keycloak-operator$/"
      ]
    },
    {
      "description": "GROUP: GitHub Actions (low-risk, can be batched)",
      "groupName": "github-actions",
      "matchManagers": [
        "github-actions"
      ]
    },
    {
      "description": "TIER 0 — Digest updates: no soak time",
      "matchUpdateTypes": [
        "digest"
      ],
      "minimumReleaseAge": "0 days",
      "labels": [
        "digest",
        "low-risk"
      ]
    },
    {
      "description": "TIER 1 — Patch updates: 2d soak",
      "matchUpdateTypes": [
        "patch"
      ],
      "minimumReleaseAge": "2 days",
      "labels": [
        "patch",
        "low-risk"
      ]
    },
    {
      "description": "TIER 2 — Minor updates: 5d soak",
      "matchUpdateTypes": [
        "minor"
      ],
      "minimumReleaseAge": "5 days",
      "labels": [
        "minor",
        "medium-risk"
      ]
    },
    {
      "description": "TIER 3 — Major updates: 7d soak + manual review",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "7 days",
      "labels": [
        "major",
        "breaking-change",
        "high-risk",
        "manual-review-required"
      ],
      "prBodyNotes": [
        "⚠️ MAJOR version update — review CHANGELOG, run kustomize-validate locally, plan rollback before merge."
      ]
    },
    {
      "description": "OVERRIDE: Critical-infrastructure — extended soak, never auto-merge",
      "matchPackageNames": [
        "/cilium/cilium/",
        "/cert-manager/cert-manager/",
        "/cloudnative-pg/cloudnative-pg/",
        "/postgresql-operator/",
        "/etcd-io/etcd/",
        "/sealed-secrets/",
        "/argoproj/argo-cd/",
        "/kyverno/kyverno/",
        "/keycloak/keycloak/",
        "/strimzi/strimzi-kafka-operator/",
        "/rook/rook/"
      ],
      "minimumReleaseAge": "7 days",
      "labels": [
        "critical-infrastructure",
        "manual-review-required",
        "high-risk"
      ]
    },
    {
      "description": "OVERRIDE: Stateful databases — extended soak",
      "matchPackageNames": [
        "/postgresql/",
        "/postgres/",
        "/mysql/",
        "/mongodb/",
        "/redis/",
        "/elasticsearch/",
        "/influxdb/"
      ],
      "matchUpdateTypes": [
        "minor",
        "major"
      ],
      "minimumReleaseAge": "7 days",
      "labels": [
        "database",
        "stateful",
        "manual-review-required"
      ]
    },
    {
      "description": "GitHub Actions: 2d soak for patches/minors",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor",
        "digest"
      ],
      "minimumReleaseAge": "2 days",
      "labels": [
        "github-actions"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Generic renovate comments in tf/tofu/tftpl/tfvars/yaml/yml/sh — supports inline registry= and versioning= hints",
      "managerFilePatterns": [
        "/\\.tf$/",
        "/\\.tofu$/",
        "/\\.tftpl$/",
        "/\\.tfvars$/",
        "/\\.yaml$/",
        "/\\.yml$/",
        "/\\.sh$/"
      ],
      "matchStrings": [
        "(?<currentValue>[\\w+\\.\\-]*)['\",;]*\\s*#\\s*renovate:\\s*(?<datasource>\\S+)=(?<depName>\\S+)(?:\\s+registry=(?<registryUrl>\\S+))?(?:\\s+versioning=(?<versioning>\\S+))?"
      ]
    },
    {
      "customType": "regex",
      "description": "Talos Docker images in k8s manifests (BLOCKED for tofu/ via packageRules — siderolabs/talos)",
      "managerFilePatterns": [
        "/\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s*(?:ghcr\\.io/)?siderolabs/talos:(?<currentValue>v?[\\d.]+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/siderolabs/talos"
    },
    {
      "customType": "regex",
      "description": "Container images in tofu/ tftpl files — Cilium values, inline-manifests, etc.",
      "managerFilePatterns": [
        "/tofu/.*\\.(yaml|yml|tftpl)$/"
      ],
      "matchStrings": [
        "image:\\s*(?<depName>(?:[\\w.-]+\\/)?[\\w.-]+\\/[\\w.-]+):(?<currentValue>v?[\\w.-]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "LLDAP date-based image tags",
      "managerFilePatterns": [
        "/lldap/.*\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s*lldap/lldap:(?<currentValue>[\\d-]+-alpine(?:-rootless)?)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "lldap/lldap",
      "versioningTemplate": "regex:^(?<major>\\d+)-(?<minor>\\d+)-(?<patch>\\d+)-alpine(?:-rootless)?$"
    }
  ],
  "gitIgnoredAuthors": [
    "tim275@users.noreply.github.com"
  ]
}
