{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:best-practices",
    ":maintainLockFilesWeekly",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "group:monorepos",
    "group:recommended"
  ],

  "configMigration": true,
  "forkProcessing": "disabled",
  "platformCommit": "enabled",
  "platformAutomerge": false,
  "automerge": false,

  "internalChecksAsSuccess": true,
  "rebaseWhen": "behind-base-branch",
  "rebaseLabel": "rebase",
  "stopUpdatingLabel": "stop-updating",
  "semanticCommits": "enabled",
  "rangeStrategy": "bump",

  "separateMinorPatch": true,
  "separateMultipleMajor": false,
  "fetchChangeLogs": "branch",

  "gitIgnoredAuthors": [
    "tim275@users.noreply.github.com"
  ],

  "assigneesFromCodeOwners": true,
  "reviewersFromCodeOwners": true,

  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths",
    "helmUpdateSubChartArchives"
  ],

  "schedule": ["* * * * *"],
  "timezone": "Europe/Berlin",
  "prConcurrentLimit": 20,
  "prHourlyLimit": 4,
  "branchConcurrentLimit": 25,

  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,
  "dependencyDashboardTitle": "🔄 Renovate Dashboard",
  "dependencyDashboardLabels": ["renovate"],
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "osvVulnerabilityAlerts": true,

  "labels": ["renovate"],
  "prHeader": "📦 Dependency Update — review CHANGELOG before merge.",
  "prBodyColumns": [
    "Package",
    "Update",
    "Type",
    "New value",
    "Pending",
    "References"
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["renovate", "security"],
    "schedule": ["at any time"],
    "automerge": false,
    "minimumReleaseAge": "0 days",
    "prCreation": "immediate"
  },

  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on sunday"],
    "automerge": false
  },

  "kubernetes": {
    "managerFilePatterns": ["/kubernetes/.+\\.ya?ml$/"]
  },
  "terraform": {
    "managerFilePatterns": ["/\\.tf$/", "/\\.tofu$/"]
  },
  "kustomize": {
    "managerFilePatterns": ["/(^|/)kustomization\\.ya?ml(\\.j2)?$/"]
  },

  "ignorePaths": [
    "**/charts/**",
    "kubernetes/components/**",
    "kubernetes/projects/**",
    "kubernetes/applicationsets/**",
    "kubernetes/clusters/**",
    "kubernetes/platform/developer-platform/backstage/**"
  ],

  "packageRules": [
    {
      "description": "BLOCK: Talos OS image (manual upgrade via talosctl)",
      "matchPackageNames": [
        "/siderolabs/talos/",
        "/siderolabs/installer/",
        "/siderolabs/imager/"
      ],
      "enabled": false
    },
    {
      "description": "BLOCK: Kubelet image (version-coupled to Talos+K8s, upgrade via talosctl)",
      "matchPackageNames": ["/siderolabs/kubelet/"],
      "enabled": false
    },
    {
      "description": "BLOCK: Kubernetes-core (manual via talosctl upgrade-k8s)",
      "matchPackageNames": [
        "/^kubernetes$/",
        "/^k8s.io/",
        "/registry.k8s.io/kube-/",
        "/etcd-io/etcd/"
      ],
      "enabled": false
    },
    {
      "description": "BLOCK: Talos-pinned system tooling (cri-tools/cni/containerd)",
      "matchPackageNames": ["/cri-tools/", "/cni-plugins/", "/containerd/"],
      "enabled": false
    },
    {
      "description": "BLOCK: tfvars version-coupling fields",
      "matchFileNames": [
        "tofu/talos_cluster.auto.tfvars",
        "tofu/talos_image.auto.tfvars"
      ],
      "matchDepNames": ["kubernetes_version", "talos_machine_config_version"],
      "enabled": false
    },

    {
      "description": "Registry override: Grafana Helm Charts (Loki/Tempo/Mimir/etc)",
      "matchDatasources": ["helm"],
      "matchPackageNames": [
        "loki",
        "tempo-distributed",
        "grafana",
        "promtail",
        "grafana-operator",
        "mimir-distributed"
      ],
      "registryUrls": ["https://grafana.github.io/helm-charts"]
    },

    {
      "description": "GROUP: Cilium project (must upgrade together)",
      "groupName": "cilium",
      "matchPackageNames": [
        "/cilium/cilium/",
        "/cilium/hubble/",
        "/cilium/cilium-cli/"
      ]
    },
    {
      "description": "GROUP: Argo project",
      "groupName": "argo-project",
      "matchPackageNames": [
        "/argoproj/argo-cd/",
        "/argoproj/argo-rollouts/",
        "/argoproj/argo-events/",
        "/argoproj/argo-workflows/",
        "/argo-cd$/",
        "/argo-rollouts$/"
      ]
    },
    {
      "description": "GROUP: Rook+Ceph (same project, must upgrade together)",
      "groupName": "rook-ceph",
      "matchPackageNames": ["/rook/", "/ceph/"]
    },
    {
      "description": "GROUP: Velero suite (plugin-coupled)",
      "groupName": "velero-suite",
      "matchPackageNames": [
        "/velero/velero/",
        "/velero/velero-plugin-/",
        "/vmware-tanzu/velero/"
      ]
    },
    {
      "description": "GROUP: CloudNativePG suite",
      "groupName": "cnpg-suite",
      "matchPackageNames": [
        "/cloudnative-pg/cloudnative-pg/",
        "/cloudnative-pg/plugin-barman-cloud/",
        "/cloudnative-pg/cnpg-i/"
      ]
    },
    {
      "description": "GROUP: Strimzi Kafka",
      "groupName": "strimzi-kafka",
      "matchPackageNames": [
        "/strimzi/strimzi-kafka-operator/",
        "/strimzi/operator/"
      ]
    },
    {
      "description": "GROUP: Keycloak",
      "groupName": "keycloak",
      "matchPackageNames": [
        "/keycloak/keycloak/",
        "/keycloak/keycloak-operator/",
        "/keycloak-operator$/"
      ]
    },
    {
      "description": "GROUP: GitHub Actions (batch low-blast-radius CI updates)",
      "groupName": "github-actions",
      "matchManagers": ["github-actions"]
    },

    {
      "description": "Type-label: digest (hash-pin, no behavior change)",
      "matchUpdateTypes": ["digest"],
      "minimumReleaseAge": "0 days",
      "addLabels": ["digest"]
    },
    {
      "description": "Type-label: patch (2d soak)",
      "matchUpdateTypes": ["patch"],
      "minimumReleaseAge": "2 days",
      "addLabels": ["patch"]
    },
    {
      "description": "Type-label: minor (5d soak)",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "5 days",
      "addLabels": ["minor"]
    },
    {
      "description": "Type-label: major (7d soak)",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "7 days",
      "addLabels": ["major"]
    },

    {
      "description": "Extra soak: critical-infrastructure (14d for minor/major)",
      "matchPackageNames": [
        "/cilium/cilium/",
        "/cert-manager/cert-manager/",
        "/cloudnative-pg/cloudnative-pg/",
        "/sealed-secrets/",
        "/argoproj/argo-cd/",
        "/kyverno/kyverno/",
        "/keycloak/keycloak/",
        "/strimzi/strimzi-kafka-operator/",
        "/rook/rook/"
      ],
      "matchUpdateTypes": ["minor", "major"],
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Extra soak: stateful databases (14d for minor/major)",
      "matchPackageNames": [
        "/postgresql/",
        "/postgres/",
        "/mysql/",
        "/mongodb/",
        "/redis/",
        "/elasticsearch/",
        "/influxdb/"
      ],
      "matchUpdateTypes": ["minor", "major"],
      "minimumReleaseAge": "14 days"
    }
  ],

  "customManagers": [
    {
      "customType": "regex",
      "description": "Generic renovate comments (supports inline registry= and versioning= hints)",
      "managerFilePatterns": [
        "/\\.tf$/",
        "/\\.tofu$/",
        "/\\.tftpl$/",
        "/\\.tfvars$/",
        "/\\.yaml$/",
        "/\\.yml$/",
        "/\\.sh$/"
      ],
      "matchStrings": [
        "(?<currentValue>[\\w+\\.\\-]*)['\",;]*\\s*#\\s*renovate:\\s*(?<datasource>\\S+)=(?<depName>\\S+)(?:\\s+registry=(?<registryUrl>\\S+))?(?:\\s+versioning=(?<versioning>\\S+))?"
      ]
    },
    {
      "customType": "regex",
      "description": "Talos Docker images in k8s manifests (BLOCKED via packageRules)",
      "managerFilePatterns": ["/\\.yaml$/"],
      "matchStrings": [
        "image:\\s*(?:ghcr\\.io/)?siderolabs/talos:(?<currentValue>v?[\\d.]+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/siderolabs/talos"
    },
    {
      "customType": "regex",
      "description": "Container images in tofu/ tftpl files (Cilium values, inline-manifests)",
      "managerFilePatterns": ["/tofu/.*\\.(yaml|yml|tftpl)$/"],
      "matchStrings": [
        "image:\\s*(?<depName>(?:[\\w.-]+\\/)?[\\w.-]+\\/[\\w.-]+):(?<currentValue>v?[\\w.-]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "LLDAP date-based image tags",
      "managerFilePatterns": ["/lldap/.*\\.yaml$/"],
      "matchStrings": [
        "image:\\s*lldap/lldap:(?<currentValue>[\\d-]+-alpine(?:-rootless)?)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "lldap/lldap",
      "versioningTemplate": "regex:^(?<major>\\d+)-(?<minor>\\d+)-(?<patch>\\d+)-alpine(?:-rootless)?$"
    }
  ]
}
