{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
    ":maintainLockFilesWeekly",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "group:monorepos",
    "group:recommended"
  ],
  "configMigration": true,
  "forkProcessing": "disabled",
  "platformCommit": "enabled",
  "automergeStrategy": "squash",
  "internalChecksAsSuccess": true,
  "transitiveRemediation": true,
  "separateMinorPatch": true,
  "separateMultipleMajor": true,
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "🔄 Renovate Dashboard",
  "dependencyDashboardLabels": [
    "renovate",
    "dependencies"
  ],
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "osvVulnerabilityAlerts": true,
  "schedule": [
    "after 21:00 every weekday",
    "before 06:00 every weekday",
    "every weekend"
  ],
  "timezone": "Europe/Berlin",
  "prConcurrentLimit": 15,
  "prHourlyLimit": 5,
  "branchConcurrentLimit": 20,
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "rebaseLabel": "rebase",
  "stopUpdatingLabel": "stop-updating",
  "internalChecksFilter": "strict",
  "semanticCommits": "enabled",
  "commitMessagePrefix": "chore(deps):",
  "labels": [
    "renovate",
    "dependencies"
  ],
  "prHeader": "📦 Dependency update — review labels for risk classification.",
  "prBodyDefinitions": {
    "OpenSSF": "[![OpenSSF Scorecard](https://api.securityscorecards.dev/projects/github.com/{{sourceUrl.replace('https://github.com/', '')}}/badge)](https://securityscorecards.dev/viewer/?uri=github.com/{{sourceUrl.replace('https://github.com/', '')}})"
  },
  "prBodyColumns": [
    "Package",
    "Update",
    "Type",
    "New value",
    "Pending",
    "OpenSSF",
    "References"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "vulnerability",
      "priority-critical",
      "fast-track"
    ],
    "schedule": [
      "at any time"
    ],
    "automerge": false,
    "minimumReleaseAge": "0 days",
    "prCreation": "immediate"
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 5am on sunday"
    ],
    "automerge": true,
    "automergeType": "branch"
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml$/",
      "/\\.yml$/"
    ]
  },
  "ignorePaths": [
    "tofu/**",
    "**/charts/**",
    "kubernetes/components/**",
    "kubernetes/projects/**",
    "kubernetes/applicationsets/**",
    "kubernetes/clusters/**"
  ],
  "packageRules": [
    {
      "description": "PARANOIA-SAFE: NIEMALS Talos via Renovate bumpen (manual via talosctl)",
      "matchPackageNames": [
        "/siderolabs/talos/",
        "/siderolabs/installer/"
      ],
      "enabled": false
    },
    {
      "description": "PARANOIA-SAFE: NIEMALS Kubernetes-Core via Renovate (manual via talosctl upgrade-k8s)",
      "matchPackageNames": [
        "/^kubernetes$/",
        "/^k8s.io/",
        "/registry.k8s.io/kube-/",
        "/etcd-io/etcd/"
      ],
      "enabled": false
    },
    {
      "description": "Block: pinned-by-Talos system tooling",
      "matchPackageNames": [
        "/cri-tools/",
        "/cni-plugins/",
        "/containerd/"
      ],
      "enabled": false
    },
    {
      "description": "Registry override: Grafana Helm Charts",
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "loki",
        "tempo-distributed",
        "grafana",
        "promtail",
        "grafana-operator",
        "mimir-distributed"
      ],
      "registryUrls": [
        "https://grafana.github.io/helm-charts"
      ]
    },
    {
      "description": "GROUP: Cilium ecosystem",
      "groupName": "Cilium CNI",
      "matchPackageNames": [
        "/cilium/"
      ]
    },
    {
      "description": "GROUP: ArgoCD ecosystem",
      "groupName": "ArgoCD Ecosystem",
      "matchPackageNames": [
        "/argo/",
        "/argocd/",
        "/argo-cd/",
        "/argo-rollouts/"
      ]
    },
    {
      "description": "GROUP: Monitoring Stack",
      "groupName": "Monitoring Stack",
      "matchPackageNames": [
        "/prometheus/",
        "/grafana/",
        "/loki/",
        "/tempo/",
        "/mimir/",
        "/victoriametrics/",
        "/alertmanager/",
        "/blackbox/",
        "/exporter/"
      ]
    },
    {
      "description": "GROUP: Security Stack",
      "groupName": "Security Stack",
      "matchPackageNames": [
        "/cert-manager/",
        "/sealed-secrets/",
        "/kyverno/",
        "/trivy/",
        "/falco/",
        "/tetragon/",
        "/kubescape/"
      ]
    },
    {
      "description": "GROUP: Storage Stack",
      "groupName": "Storage Stack",
      "matchPackageNames": [
        "/rook/",
        "/ceph/",
        "/velero/",
        "/longhorn/",
        "/minio/",
        "/csi-/"
      ]
    },
    {
      "description": "GROUP: Messaging Stack",
      "groupName": "Messaging Stack",
      "matchPackageNames": [
        "/kafka/",
        "/strimzi/",
        "/redpanda/",
        "/rabbitmq/",
        "/nats/",
        "/apicurio/"
      ]
    },
    {
      "description": "GROUP: Identity Stack",
      "groupName": "Identity Stack",
      "matchPackageNames": [
        "/keycloak/",
        "/authelia/",
        "/lldap/",
        "/dex/",
        "/oauth2-proxy/",
        "/authentik/"
      ]
    },
    {
      "description": "GROUP: Observability Stack (traces+logs)",
      "groupName": "Observability Stack",
      "matchPackageNames": [
        "/jaeger/",
        "/opentelemetry/",
        "/elasticsearch/",
        "/kibana/",
        "/fluent/",
        "/vector/"
      ]
    },
    {
      "description": "GROUP: VPN + Network",
      "groupName": "VPN Network Stack",
      "matchPackageNames": [
        "/tailscale/",
        "/cloudflare/",
        "/cloudflared/",
        "/netbird/",
        "/wireguard/"
      ]
    },
    {
      "description": "GROUP: GitHub Actions",
      "groupName": "GitHub Actions",
      "matchManagers": [
        "github-actions"
      ]
    },
    {
      "description": "TIER 1 — PATCH (non-critical): auto-merge after 2d stability + n8n review",
      "matchUpdateTypes": [
        "patch"
      ],
      "matchPackageNames": [
        "!/cilium/",
        "!/cert-manager/",
        "!/cloudnative-pg/",
        "!/postgresql/",
        "!/postgres/",
        "!/etcd/",
        "!/barman-cloud/",
        "!/sealed-secrets/",
        "!/talos/",
        "!/argocd/",
        "!/argo-cd/",
        "!/kyverno/",
        "!/keycloak/",
        "!/strimzi/",
        "!/rook/",
        "!/ceph/"
      ],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true,
      "minimumReleaseAge": "2 days",
      "labels": [
        "patch",
        "low-risk",
        "auto-merge-candidate"
      ]
    },
    {
      "description": "TIER 2 — MINOR (non-critical): auto-merge after 5d stability + n8n review",
      "matchUpdateTypes": [
        "minor"
      ],
      "matchPackageNames": [
        "!/cilium/",
        "!/cert-manager/",
        "!/cloudnative-pg/",
        "!/postgresql/",
        "!/postgres/",
        "!/etcd/",
        "!/barman-cloud/",
        "!/sealed-secrets/",
        "!/talos/",
        "!/argocd/",
        "!/argo-cd/",
        "!/kyverno/",
        "!/keycloak/",
        "!/strimzi/",
        "!/rook/",
        "!/ceph/",
        "!/redis/",
        "!/elasticsearch/",
        "!/mongodb/"
      ],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true,
      "minimumReleaseAge": "5 days",
      "labels": [
        "minor",
        "medium-risk",
        "auto-merge-candidate"
      ]
    },
    {
      "description": "TIER 3 — CRITICAL infrastructure: NEVER auto-merge, 7d stability",
      "matchPackageNames": [
        "/cilium/",
        "/cert-manager/",
        "/cloudnative-pg/",
        "/postgresql/",
        "/postgres/",
        "/etcd/",
        "/barman-cloud/",
        "/sealed-secrets/",
        "/talos/",
        "/argocd/",
        "/argo-cd/",
        "/kyverno/"
      ],
      "automerge": false,
      "minimumReleaseAge": "7 days",
      "labels": [
        "critical-infrastructure",
        "manual-review-required",
        "high-risk"
      ],
      "reviewers": [
        "Tim275"
      ]
    },
    {
      "description": "TIER 4 — Stateful databases: manual review, 7d stability",
      "matchPackageNames": [
        "/postgres/",
        "/mysql/",
        "/mongodb/",
        "/redis/",
        "/elasticsearch/",
        "/influxdb/"
      ],
      "automerge": false,
      "minimumReleaseAge": "7 days",
      "labels": [
        "database",
        "stateful",
        "manual-review-required"
      ]
    },
    {
      "description": "TIER 5 — MAJOR updates: require manual review + 7d soak",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "minimumReleaseAge": "7 days",
      "labels": [
        "major",
        "breaking-change",
        "high-risk",
        "manual-review-required"
      ],
      "reviewers": [
        "Tim275"
      ],
      "prBodyNotes": [
        "⚠️ MAJOR version update — review CHANGELOG, run kustomize-validate locally, plan rollback before merge."
      ]
    },
    {
      "description": "Docker digest pinning updates: auto-merge instantly",
      "matchUpdateTypes": [
        "digest"
      ],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true,
      "minimumReleaseAge": "0 days",
      "labels": [
        "digest",
        "auto-merge-candidate"
      ]
    },
    {
      "description": "GitHub Actions: auto-merge after 2d stability",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor",
        "digest"
      ],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true,
      "minimumReleaseAge": "2 days",
      "labels": [
        "github-actions",
        "auto-merge-candidate"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Generic renovate comments in tf/yaml/yml/sh files (kubernetes/ only — tofu/ excluded via ignorePaths)",
      "managerFilePatterns": [
        "/\\.tf$/",
        "/\\.yaml$/",
        "/\\.yml$/",
        "/\\.sh$/"
      ],
      "matchStrings": [
        "(?<currentValue>[\\w+\\.\\-]*)['\",;]*\\s*#\\s*renovate:\\s*(?<datasource>\\S+)=(?<depName>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Talos Docker images (k8s manifests only — tofu/ ignored)",
      "managerFilePatterns": [
        "/\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s*(?:ghcr\\.io/)?siderolabs/talos:(?<currentValue>v?[\\d.]+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/siderolabs/talos"
    },
    {
      "customType": "regex",
      "description": "Helm charts in kustomization with renovate comment",
      "managerFilePatterns": [
        "/kustomization\\.yaml$/"
      ],
      "matchStrings": [
        "version:\\s*[\"']?(?<currentValue>[\\d.]+)[\"']?\\s*#\\s*renovate:\\s*helm=(?<registryUrl>[^/]+)/(?<depName>\\S+)"
      ],
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://{{registryUrl}}.github.io/helm-charts"
    },
    {
      "customType": "regex",
      "description": "LLDAP date-based image tags",
      "managerFilePatterns": [
        "/lldap/.*\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s*lldap/lldap:(?<currentValue>[\\d-]+-alpine(?:-rootless)?)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "lldap/lldap",
      "versioningTemplate": "regex:^(?<major>\\d+)-(?<minor>\\d+)-(?<patch>\\d+)-alpine(?:-rootless)?$"
    }
  ]
}
