{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
    ":maintainLockFilesWeekly",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "group:monorepos",
    "group:recommended"
  ],
  "configMigration": true,
  "forkProcessing": "disabled",
  "platformCommit": true,
  "automergeStrategy": "squash",
  "internalChecksAsSuccess": true,
  "transitiveRemediation": true,
  "separateMinorPatch": true,
  "separateMultipleMajor": true,
  "fetchChangeLogs": "branch",
  "assigneesFromCodeOwners": true,
  "reviewersFromCodeOwners": true,
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths",
    "helmUpdateSubChartArchives"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,
  "dependencyDashboardTitle": "🔄 Renovate Dashboard",
  "dependencyDashboardLabels": [
    "renovate",
    "dependencies"
  ],
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "osvVulnerabilityAlerts": true,
  "schedule": [
    "* * * * *"
  ],
  "timezone": "Europe/Berlin",
  "prConcurrentLimit": 30,
  "prHourlyLimit": 10,
  "branchConcurrentLimit": 35,
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "rebaseLabel": "rebase",
  "stopUpdatingLabel": "stop-updating",
  "semanticCommits": "enabled",
  "labels": [
    "renovate",
    "dependencies"
  ],
  "prHeader": "📦 Dependency update — review labels for risk classification.",
  "prBodyColumns": [
    "Package",
    "Update",
    "Type",
    "New value",
    "Pending",
    "References"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "vulnerability",
      "priority-critical",
      "fast-track"
    ],
    "schedule": [
      "at any time"
    ],
    "automerge": false,
    "minimumReleaseAge": "0 days",
    "prCreation": "immediate"
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 5am on sunday"
    ],
    "automerge": false
  },
  "ignorePaths": [
    "tofu/**",
    "**/charts/**",
    "kubernetes/components/**",
    "kubernetes/projects/**",
    "kubernetes/applicationsets/**",
    "kubernetes/clusters/**",
    "kubernetes/platform/developer-platform/backstage/**"
  ],
  "packageRules": [
    {
      "description": "BLOCK: Talos versioning — manual via talosctl upgrade",
      "matchPackageNames": [
        "/siderolabs/talos/",
        "/siderolabs/installer/"
      ],
      "enabled": false
    },
    {
      "description": "BLOCK: Kubernetes-core — manual via talosctl upgrade-k8s",
      "matchPackageNames": [
        "/^kubernetes$/",
        "/^k8s.io/",
        "/registry.k8s.io/kube-/",
        "/etcd-io/etcd/"
      ],
      "enabled": false
    },
    {
      "description": "BLOCK: Talos-pinned system tooling",
      "matchPackageNames": [
        "/cri-tools/",
        "/cni-plugins/",
        "/containerd/"
      ],
      "enabled": false
    },
    {
      "description": "Registry override: Grafana Helm Charts (Loki/Tempo/Mimir/etc)",
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "loki",
        "tempo-distributed",
        "grafana",
        "promtail",
        "grafana-operator",
        "mimir-distributed"
      ],
      "registryUrls": [
        "https://grafana.github.io/helm-charts"
      ]
    },
    {
      "description": "GROUP: Cilium project (cilium + hubble + cilium-cli)",
      "groupName": "cilium",
      "matchPackageNames": [
        "/cilium/cilium/",
        "/cilium/hubble/",
        "/cilium/cilium-cli/"
      ]
    },
    {
      "description": "GROUP: Argo project (argo-cd + argo-rollouts + argo-events + argo-workflows)",
      "groupName": "argo-project",
      "matchPackageNames": [
        "/argoproj/argo-cd/",
        "/argoproj/argo-rollouts/",
        "/argoproj/argo-events/",
        "/argoproj/argo-workflows/",
        "/argo-cd$/",
        "/argo-rollouts$/"
      ]
    },
    {
      "description": "GROUP: Rook+Ceph (same project, must upgrade together)",
      "groupName": "rook-ceph",
      "matchPackageNames": [
        "/rook/",
        "/ceph/"
      ]
    },
    {
      "description": "GROUP: Velero suite (velero + velero-plugin-* — version-coupled)",
      "groupName": "velero-suite",
      "matchPackageNames": [
        "/velero/velero/",
        "/velero/velero-plugin-/",
        "/vmware-tanzu/velero/"
      ]
    },
    {
      "description": "GROUP: CloudNativePG operator + plugin-barman",
      "groupName": "cnpg-suite",
      "matchPackageNames": [
        "/cloudnative-pg/cloudnative-pg/",
        "/cloudnative-pg/plugin-barman-cloud/",
        "/cloudnative-pg/cnpg-i/"
      ]
    },
    {
      "description": "GROUP: Strimzi Kafka operator + CRDs",
      "groupName": "strimzi-kafka",
      "matchPackageNames": [
        "/strimzi/strimzi-kafka-operator/",
        "/strimzi/operator/"
      ]
    },
    {
      "description": "GROUP: Keycloak operator + CR + CLI",
      "groupName": "keycloak",
      "matchPackageNames": [
        "/keycloak/keycloak/",
        "/keycloak/keycloak-operator/",
        "/keycloak-operator$/"
      ]
    },
    {
      "description": "GROUP: GitHub Actions (low-risk, can be batched)",
      "groupName": "github-actions",
      "matchManagers": [
        "github-actions"
      ]
    },
    {
      "description": "TIER 0 — Digest updates: no soak time",
      "matchUpdateTypes": [
        "digest"
      ],
      "minimumReleaseAge": "0 days",
      "labels": [
        "digest",
        "low-risk"
      ]
    },
    {
      "description": "TIER 1 — Patch updates: 2d soak",
      "matchUpdateTypes": [
        "patch"
      ],
      "minimumReleaseAge": "2 days",
      "labels": [
        "patch",
        "low-risk"
      ]
    },
    {
      "description": "TIER 2 — Minor updates: 5d soak",
      "matchUpdateTypes": [
        "minor"
      ],
      "minimumReleaseAge": "5 days",
      "labels": [
        "minor",
        "medium-risk"
      ]
    },
    {
      "description": "TIER 3 — Major updates: 7d soak + manual review",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "7 days",
      "labels": [
        "major",
        "breaking-change",
        "high-risk",
        "manual-review-required"
      ],
      "prBodyNotes": [
        "⚠️ MAJOR version update — review CHANGELOG, run kustomize-validate locally, plan rollback before merge."
      ]
    },
    {
      "description": "OVERRIDE: Critical-infrastructure — extended soak, never auto-merge",
      "matchPackageNames": [
        "/cilium/cilium/",
        "/cert-manager/cert-manager/",
        "/cloudnative-pg/cloudnative-pg/",
        "/postgresql-operator/",
        "/etcd-io/etcd/",
        "/sealed-secrets/",
        "/argoproj/argo-cd/",
        "/kyverno/kyverno/",
        "/keycloak/keycloak/",
        "/strimzi/strimzi-kafka-operator/",
        "/rook/rook/"
      ],
      "minimumReleaseAge": "7 days",
      "labels": [
        "critical-infrastructure",
        "manual-review-required",
        "high-risk"
      ]
    },
    {
      "description": "OVERRIDE: Stateful databases — extended soak",
      "matchPackageNames": [
        "/postgresql/",
        "/postgres/",
        "/mysql/",
        "/mongodb/",
        "/redis/",
        "/elasticsearch/",
        "/influxdb/"
      ],
      "matchUpdateTypes": [
        "minor",
        "major"
      ],
      "minimumReleaseAge": "7 days",
      "labels": [
        "database",
        "stateful",
        "manual-review-required"
      ]
    },
    {
      "description": "GitHub Actions: 2d soak for patches/minors",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor",
        "digest"
      ],
      "minimumReleaseAge": "2 days",
      "labels": [
        "github-actions"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Generic renovate comments in tf/yaml/yml/sh files (kubernetes/ only — tofu/ excluded via ignorePaths)",
      "managerFilePatterns": [
        "/\\.tf$/",
        "/\\.yaml$/",
        "/\\.yml$/",
        "/\\.sh$/"
      ],
      "matchStrings": [
        "(?<currentValue>[\\w+\\.\\-]*)['\",;]*\\s*#\\s*renovate:\\s*(?<datasource>\\S+)=(?<depName>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Talos Docker images (k8s manifests only — tofu/ ignored)",
      "managerFilePatterns": [
        "/\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s*(?:ghcr\\.io/)?siderolabs/talos:(?<currentValue>v?[\\d.]+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/siderolabs/talos"
    },
    {
      "customType": "regex",
      "description": "LLDAP date-based image tags",
      "managerFilePatterns": [
        "/lldap/.*\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s*lldap/lldap:(?<currentValue>[\\d-]+-alpine(?:-rootless)?)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "lldap/lldap",
      "versioningTemplate": "regex:^(?<major>\\d+)-(?<minor>\\d+)-(?<patch>\\d+)-alpine(?:-rootless)?$"
    }
  ]
}