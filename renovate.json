{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs",
    ":dependencyDashboard",
    ":semanticCommits",
    "docker:enableMajor",
    ":automergeDigest"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dashboard 🤖",
  "terraform": {
    "managerFilePatterns": [
      "/\\.tf$/",
      "/\\.tofu$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/kubernetes/.+\\.yaml$/",
      "/kubernetes/.+\\.yml$/"
    ]
  },
  "kustomize": {
    "managerFilePatterns": [
      "/(^|/)kustomization\\.ya?ml(\\.j2)?$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.tf$/",
        "/\\.tofu$/",
        "/\\.tftpl$/",
        "/\\.yaml$/",
        "/\\.yml$/",
        "/\\.sh$/",
        "/\\.tfvars$/"
      ],
      "matchStrings": [
        "(?<currentValue>[\\w+\\.\\-]*)['\",;]*\\s*#\\s?renovate: (?<datasource>\\S+)=(?<depName>\\S+)\\s?(registry=(?<registryUrl>\\S+))?\\s?(versioning=(?<versioning>\\S+))?",
        "talos_version\\s*=\\s*\"(?<currentValue>.*?)\"",
        "kubernetes_version\\s*=\\s*\"(?<currentValue>.*?)\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "siderolabs/talos"
    }
  ],
  "packageRules": [
    {
      "groupName": "Talos System",
      "matchPackageNames": [
        "siderolabs/talos",
        "**/talos**"
      ]
    },
    {
      "groupName": "Monitoring Stack",
      "matchPackageNames": [
        "prometheus-community/**",
        "grafana/**",
        "**/loki**",
        "**/promtail**"
      ]
    },
    {
      "groupName": "ArgoCD",
      "matchPackageNames": [
        "**/argo-cd**",
        "argoproj/**"
      ]
    },
    {
      "groupName": "Cilium",
      "matchPackageNames": [
        "/cilium/"
      ]
    },
    {
      "matchManagers": [
        "terraform"
      ],
      "matchDepTypes": [
        "provider",
        "required_provider"
      ],
      "groupName": "Terraform Providers"
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    },
    {
      "description": "Auto-merge container digests",
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
      "automerge": true
    },
    {
      "description": "Auto-merge minor and patch",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "automergeType": "branch"
    }
  ]
}
